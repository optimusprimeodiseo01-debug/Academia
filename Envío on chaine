// nodes/contrato.js
const { ethers } = require("ethers");

const RPC = "https://rpc.tu-red";
const provider = new ethers.providers.JsonRpcProvider(RPC);

// clave que ejecuta la tx
const EXECUTOR_KEY = "0xTU_PRIVATE_KEY";
const wallet = new ethers.Wallet(EXECUTOR_KEY, provider);

const ABI = [
  "function verificar(address user,uint256 exp,uint256 nonce,bytes firma) public returns (bool)"
];

const CONTRACT_ADDRESS = "0xTU_CONTRATO";

const contract = new ethers.Contract(CONTRACT_ADDRESS, ABI, wallet);

module.exports = async (state) => {
  try {
    const tx = await contract.verificar(
      state.user,
      state.exp,
      state.nonce,
      state.firma
    );

    await tx.wait();

    return {
      ...state,
      tx_hash: tx.hash,
      acceso_onchain: true
    };

  } catch (e) {
    return { error: e.message };
  }
};
